{
  "name": "@lojacelular/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @lojacelular/shared build && nest start --watch",
    "build": "pnpm --filter @lojacelular/shared build && nest build",
    "start": "node dist/main.js",
    "typecheck": "pnpm --filter @lojacelular/shared build && tsc -p tsconfig.json --noEmit",
    "lint": "pnpm --filter @lojacelular/shared build && tsc -p tsconfig.json --noEmit",
    "prisma": "prisma",
    "prisma:generate": "prisma generate --config ../../prisma.config.ts",
    "prisma:migrate:dev": "prisma migrate dev --config ../../prisma.config.ts",
    "prisma:seed": "tsx ../../prisma/seed.ts"
  },
  "dependencies": {
    "@lojacelular/shared": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.6.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.10.2",
    "prisma": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
